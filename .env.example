# ---------------------------------------------------------------------------
# Per-brand build selector (REQUIRED). One Vercel project per brand sets this.
# One of: off-the-hook | high-ground | countersuit | spearhead | steelpoint | rally-point
BRAND=off-the-hook

# ---------------------------------------------------------------------------
# Lead capture (OPTIONAL). If both are set, /api/lead inserts to Supabase.
# If unset, submissions are logged to the server console instead (no data lost
# during early build). Provision a `leads` table — see README.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Analytics (OPTIONAL, per brand). Wired into <head> when present.
PUBLIC_GA4_ID=
PUBLIC_META_PIXEL_ID=

# ---------------------------------------------------------------------------
# Per-brand contact (OPTIONAL). Surfaced in header/footer + intake when set.
PUBLIC_INTAKE_PHONE=
PUBLIC_CONSULT_URL=
