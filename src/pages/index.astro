---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import HowItWorks from "@/components/HowItWorks.astro";
import WhoWeHelp from "@/components/WhoWeHelp.astro";
import WhyUs from "@/components/WhyUs.astro";
import Results from "@/components/Results.astro";
import Section from "@/components/Section.astro";
import LeadForm from "@/components/LeadForm.astro";
import { brand } from "@/lib/brand";
---

<BaseLayout>
  <Hero />
  <WhoWeHelp />
  <HowItWorks />
  <WhyUs />
  <Results />

  <Section id="contact" tone="tint">
    <div class="grid items-center gap-10 lg:grid-cols-[1fr_1.05fr]">
      <div>
        <p class="eyebrow">Get started</p>
        <h2 class="mt-3 text-[clamp(1.9rem,4vw,2.9rem)] font-extrabold" style="color:var(--c-dark)">
          {brand.taglinesSecondary[0] ?? brand.taglinePrimary}
        </h2>
        <p class="mt-4 text-lg" style="color:var(--c-supporting)">
          {brand.positioning}
        </p>
      </div>
      <LeadForm />
    </div>
  </Section>
</BaseLayout>
