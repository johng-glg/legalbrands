---
/**
 * Renders the brand's `mindset`, `audience`, and `triggers` from config.
 */
import { brand } from "@/lib/brand";
import Section from "@/components/Section.astro";
---

<Section eyebrow="Who we help" title="If this sounds like you, you're in the right place">
  <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
    <div>
      <p class="font-head text-2xl md:text-3xl font-bold leading-snug" style="color:var(--c-primary)">
        {brand.mindset}
      </p>
      <p class="mt-5 text-lg leading-relaxed" style="color:var(--c-supporting)">
        {brand.audience}
      </p>
    </div>

    <div>
      <p class="font-head font-semibold mb-4" style="color:var(--c-dark)">What usually brings people to us:</p>
      <ul class="grid gap-3 sm:grid-cols-2">
        {brand.triggers.map((t) => (
          <li class="flex items-start gap-3 rounded-xl p-4"
            style="background-color:color-mix(in srgb, var(--c-primary) 6%, var(--c-light)); border:1px solid color-mix(in srgb, var(--c-supporting) 16%, transparent)">
            <span aria-hidden="true" class="mt-1 inline-block h-2.5 w-2.5 rounded-full shrink-0" style="background-color:var(--c-primary)"></span>
            <span class="text-[0.97rem]" style="color:var(--c-dark)">{t}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</Section>
