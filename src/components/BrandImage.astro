---
/**
 * Renders a brand photo via Astro's <Image> (optimized to WebP at display
 * size), or a palette-colored placeholder (gradient of primary -> dark with
 * the brand initial) when the file is missing.
 */
import { Image } from "astro:assets";
import { brand } from "@/lib/brand";
import { img, type RasterAsset } from "@/lib/assets";

interface Props {
  file: Extract<RasterAsset, "hero.png" | "secondary.png">;
  alt?: string;
  class?: string;
  width?: number;
}
const { file, alt = "", class: className = "", width = 900 } = Astro.props;
const meta = img(file);
const initial = brand.name.charAt(0);
---

{
  meta ? (
    <Image
      src={meta}
      alt={alt}
      width={width}
      format="webp"
      quality={72}
      class={`object-cover ${className}`}
    />
  ) : (
    <div
      class={`grid place-items-center ${className}`}
      style="background-image:linear-gradient(135deg, var(--c-primary), var(--c-dark));"
      role="img"
      aria-label={alt || `${brand.name} placeholder image`}
    >
      <span class="font-head font-extrabold opacity-25" style="color:var(--c-light); font-size:clamp(4rem,12vw,9rem)">
        {initial}
      </span>
    </div>
  )
}
