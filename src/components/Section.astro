---
/**
 * Generic section wrapper for consistent rhythm. `tone` switches the surface:
 * 'light' (default), 'tint' (faint primary wash), or 'dark' (reverse).
 * `texture` overlays the brand's texture-1 as a very faint section background
 * (optimized to WebP) — kept low-contrast so copy always reads over it.
 */
import { getImage } from "astro:assets";
import { img } from "@/lib/assets";

interface Props {
  eyebrow?: string;
  title?: string;
  intro?: string;
  tone?: "light" | "tint" | "dark";
  id?: string;
  class?: string;
  texture?: boolean;
}
const { eyebrow, title, intro, tone = "light", id, class: className = "", texture = false } = Astro.props;

const bg =
  tone === "dark"
    ? "background-color:var(--c-dark)"
    : tone === "tint"
      ? "background-color:color-mix(in srgb, var(--c-primary) 7%, var(--c-light))"
      : "background-color:var(--c-light)";
const titleColor = tone === "dark" ? "var(--c-light)" : "var(--c-dark)";
const introColor = tone === "dark" ? "color-mix(in srgb, var(--c-light) 80%, transparent)" : "var(--c-supporting)";

const texMeta = texture ? img("texture-1.png") : null;
const texGen = texMeta ? await getImage({ src: texMeta, width: 1600, format: "webp" }) : null;
const texOpacity = tone === "dark" ? 0.1 : 0.07;
---

<section id={id} class={`relative overflow-hidden py-16 md:py-24 ${className}`} style={bg}>
  {texGen && (
    <div
      class="pointer-events-none absolute inset-0"
      aria-hidden="true"
      style={`background-image:url(${texGen.src});background-size:cover;background-position:center;opacity:${texOpacity}`}
    >
    </div>
  )}
  <div class="container-rail relative">
    {(eyebrow || title || intro) && (
      <div class="max-w-3xl mb-12">
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        {title && <h2 class="mt-3 text-[clamp(1.9rem,4vw,2.9rem)] font-extrabold" style={`color:${titleColor}`}>{title}</h2>}
        {intro && <p class="mt-4 text-lg" style={`color:${introColor}`}>{intro}</p>}
      </div>
    )}
    <slot />
  </div>
</section>
